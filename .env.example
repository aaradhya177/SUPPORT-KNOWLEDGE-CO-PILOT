# Embedding model used for dense vector representations.
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# LLM provider identifier used by generation, verification, and grading modules.
LLM_PROVIDER=gemini

# API key for the configured LLM provider. For Gemini, paste your Gemini API key here.
LLM_API_KEY=your-api-key-here

# API key accepted by normal protected endpoints such as POST /api/v1/query.
SUPPORT_COPILOT_API_KEY=replace-with-a-long-random-user-key

# Admin API key accepted by privileged endpoints such as ingestion and evaluation.
SUPPORT_COPILOT_ADMIN_API_KEY=replace-with-a-long-random-admin-key

# LLM model name used by future generation and judge workflows.
LLM_MODEL_NAME=gemini-flash-lite-latest

# Maximum token or character chunk size for future document chunking.
CHUNK_SIZE=800

# Overlap between adjacent chunks for future document chunking.
CHUNK_OVERLAP=120

# Filesystem path for future FAISS dense index artifacts.
DENSE_INDEX_PATH=indexes/dense

# Filesystem path for future BM25 sparse index artifacts.
BM25_INDEX_PATH=indexes/sparse

# Enable optional cross-encoder reranking after hybrid dense + BM25 fusion.
ENABLE_RERANKER=false

# SentenceTransformers CrossEncoder model used when ENABLE_RERANKER=true.
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# SQLite database path used to persist ingestion job history.
INGESTION_JOBS_DB_PATH=data/processed/ingestion_jobs.sqlite3

# SQLite database path used to persist answer feedback.
FEEDBACK_DB_PATH=data/processed/feedback.sqlite3

# Enable persistent caching for citation verification judge calls.
ENABLE_JUDGE_CACHE=true

# SQLite database path used to cache citation verification judge results.
JUDGE_CACHE_DB_PATH=data/processed/judge_cache.sqlite3

# Minimum confidence score required before returning an answer.
CONFIDENCE_THRESHOLD=0.55

# Maximum POST /api/v1/query requests per API key within the configured window.
QUERY_RATE_LIMIT_REQUESTS=60

# Sliding-window size in seconds for POST /api/v1/query rate limiting.
QUERY_RATE_LIMIT_WINDOW_SECONDS=60

# Application log level. Common values: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Streamlit frontend backend URL. Docker Compose overrides this to http://backend:8000.
BACKEND_URL=http://localhost:8000

# Optional production compose image names and bind settings.
BACKEND_IMAGE=support-knowledge-copilot-backend:prod
FRONTEND_IMAGE=support-knowledge-copilot-frontend:prod
FRONTEND_BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=8501
